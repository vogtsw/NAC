# NAC (NexusAgent-Cluster) 环境变量配置模板
# 复制此文件为 .env 并填入实际的值

# ============================================
# LLM API 配置
# ============================================

# DeepSeek API (必需)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Zhipu AI (智谱 AI) API (可选)
# 获取地址: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============================================
# 存储
# ============================================

# Redis URL (用于会话存储，可选)
REDIS_URL=redis://localhost:6379

# ============================================
# 安全配置
# ============================================

# 密钥 (生产环境必须更改)
SECRET_KEY=your-secret-key-change-this-in-production

# ============================================
# Agent 配置
# ============================================

# 集群名称
CLUSTER_NAME=nexus-agent-cluster

# 环境
CLUSTER_ENVIRONMENT=development

# 最大并行 Agent 数量
CLUSTER_MAX_PARALLEL_AGENTS=10

# ============================================
# LLM 配置
# ============================================

# LLM Provider (deepseek, zhipu, openai)
ORCHESTRATOR_PROVIDER=deepseek

# LLM Model
ORCHESTRATOR_MODEL=deepseek-chat

# 超时时间 (秒)
ORCHESTRATOR_TIMEOUT_SECONDS=90

# ============================================
# API 服务器
# ============================================

# 主机地址
API_HOST=0.0.0.0

# 端口
API_PORT=3000

# ============================================
# 监控与日志
# ============================================

# 日志级别: ERROR | WARN | INFO | DEBUG
LOG_LEVEL=INFO

# 启用指标收集
METRICS_ENABLED=true
